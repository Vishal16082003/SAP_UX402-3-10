<mvc:View
    controllerName="demo.mock.mocky.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">


   <App>
    <Page title="SAPUI5 Mock Server Demo">

        <content>

            <Table items="{/Products}">

                <columns>
                    <Column>
                        <Text text="ID"/>
                    </Column>

                    <Column>
                        <Text text="Name"/>
                    </Column>
<Column>
                        <Text text="Price"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{ID}"/>
                            <Text text="{Name}"/>
                            <Text text="{Price}"/>
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>

        </content>

    </Page>
   </App>
    </mvc:View>