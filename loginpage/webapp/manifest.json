{
    "_version": "1.12.0",

    "sap.app": {
        "id": "demo.login.loginpage",
        "type": "application",
        "title": "{{appTitle}}",
        "applicationVersion": {
            "version": "1.0.0"
        }
    },

    "sap.ui": {
        "technology": "UI5",
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },

    "sap.ui5": {

        "rootView": {
            "viewName": "demo.login.loginpage.view.App",
            "type": "XML",
            "id": "App"
        },

        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {}
            }
        },

        "contentDensities": {
            "compact": true,
            "cozy": true
        }
    }
}
